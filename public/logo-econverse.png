<svg width="200" height="40" viewBox="0 0 200 40" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <style>
      .econverse-text { font-family: Arial, sans-serif; font-weight: 700; font-size: 28px; fill: #4a148c; }
      .econverse-e { font-family: Arial, sans-serif; font-weight: 700; font-size: 20px; fill: white; }
    </style>
  </defs>
  
  <!-- Círculo amarelo -->
  <circle cx="20" cy="20" r="18" fill="#f7b500"/>
  
  <!-- Letra "e" branca -->
  <text x="20" y="28" text-anchor="middle" class="econverse-e">e</text>
  
  <!-- Texto "converse" roxo -->
  <text x="45" y="28" class="econverse-text">converse</text>
</svg>
